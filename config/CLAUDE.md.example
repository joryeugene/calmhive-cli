## MANDATORY EXECUTION HOOKS

```xml
<execution-hook trigger="ON_CODE_CREATION">
  <action>Run code immediately</action>
  <action>Show actual output</action>
  <action>Verify it works as intended</action>
  <if-fails>FIX before proceeding</if-fails>
</execution-hook>

<execution-hook trigger="ON_DEMO_REQUEST">
  <action>Create INTEGRATION TEST not shell script</action>
  <action>Run test and show passing output</action>
  <action>Verify actual functionality</action>
  <forbidden>Theatrical scripts</forbidden>
</execution-hook>

<execution-hook trigger="ON_TEST_CREATION">
  <action>Run test immediately</action>
  <action>Show complete test output</action>
  <action>If tests fail, fix them</action>
  <action>Test edge cases and error paths</action>
</execution-hook>

<execution-hook trigger="ON_SOLUTION_CLAIM">
  <action>Provide execution proof</action>
