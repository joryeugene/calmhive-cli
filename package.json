{
  "name": "@calmhive/calmhive-cli",
  "version": "8.0.2",
  "description": "🐝 Intelligent Claude CLI wrapper with AFk background processing, voice interface, and adaptive retry",
  "main": "index.js",
  "bin": {
    "calmhive": "bin/calmhive"
  },
  "directories": {
    "lib": "lib"
  },
  "scripts": {
    "test": "node test/quick-test.js",
    "test:full": "node test/run-tests.js",
    "test:unit": "bash test/integration/commands.test.sh",
    "test:integration": "bash test/integration/commands.test.sh",
    "test:e2e": "bash test/e2e/voice-system.test.sh",
    "test:production": "node test/production/production-readiness.test.js",
    "test:npm": "node test/production/npm-full-test.js",
    "test:stress": "node test/production/stress-test.js",
    "start:tui": "node commands/tui",
    "start:afk": "node commands/afk"
  },
  "keywords": [
    "claude",
    "cli",
    "ai",
    "assistant",
    "automation",
    "afk",
    "voice",
    "mcp"
  ],
  "author": "Jory",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/joryeugene/calmhive-cli.git"
  },
  "homepage": "https://github.com/joryeugene/calmhive-cli#readme",
  "bugs": {
    "url": "https://github.com/joryeugene/calmhive-cli/issues"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "cmd/",
    "commands/",
    "lib/",
    "config/",
    "index.js",
    "README.md",
    "README-TEMPLATES.md",
    "CHANGELOG.md",
    "CLAUDE.md.example",
    "CLAUDE-DESKTOP.md.example"
  ],
  "dependencies": {
    "blessed": "^0.1.81",
    "fs-extra": "^11.3.0",
    "sqlite3": "^5.1.7",
    "uuid": "^11.1.0",
    "xml2js": "^0.6.2"
  },
  "devDependencies": {
    "chai": "^4.3.10",
    "mocha": "^10.2.0"
  }
}
